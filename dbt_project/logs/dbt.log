flattened_immunizations AS (
  SELECT
    -- Identifiers
    json_extract_scalar(entry_json, '$.resource.id') AS immunization_id,
    
    -- Foreign Keys
    REPLACE(
      json_extract_scalar(entry_json, '$.resource.patient.reference'),
      'urn:uuid:',
